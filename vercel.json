{
  "cleanUrls": true,
  "trailingSlash": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/brand_assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/home",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/lca-gww/",
      "destination": "/kennisbank/lca-in-de-gww/",
      "permanent": true
    },
    {
      "source": "/lca-aanbestedingen-gww/",
      "destination": "/kennisbank/lca-in-aanbestedingen/",
      "permanent": true
    },
    {
      "source": "/over.html",
      "destination": "/over-ons/",
      "permanent": true
    },
    {
      "source": "/projecten.html",
      "destination": "/projecten/",
      "permanent": true
    },
    {
      "source": "/artikelen/wat-is-lca/",
      "destination": "/artikelen/wat-is-een-lca/",
      "permanent": true
    },
    {
      "source": "/mki-berekening-gww/",
      "destination": "/diensten/mki-berekening/",
      "permanent": true
    },
    {
      "source": "/epd-en-15804/",
      "destination": "/kennisbank/epd-en-normen/",
      "permanent": true
    },
    {
      "source": "/epd-checker.html",
      "destination": "/tooling/",
      "permanent": true
    },
    {
      "source": "/lca-project-tool/",
      "destination": "/tooling/",
      "permanent": true
    }
  ]
}
